{
  "name": "submit-hunt",
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "build:css": "tailwindcss -i scripts/tailwind-input.css -o vendor/tailwind.css --minify",
    "build:vendor": "node scripts/build-vendor.js",
    "build": "npm run build:vendor && npm run build:css",
    "watch:css": "tailwindcss -i scripts/tailwind-input.css -o vendor/tailwind.css --watch",
    "supabase:typegen": "bunx supabase gen types --lang=typescript --local > supabase/database-generated.types.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.38.4",
    "live-server": "^1.2.2",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@vercel/analytics": "^1.1.1",
    "esbuild": "^0.28.0",
    "htm": "^3.1.1",
    "preact": "^10.13.1"
  }
}
